{
  "name": "dens-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Windows Minecraft launcher with portable data storage, profiles, mods, servers and local accounts.",
  "author": "DENS",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5267 --strictPort",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5267 && set ELECTRON_DISABLE_GPU=1&& set VITE_DEV_SERVER_URL=http://127.0.0.1:5267&& electron . --disable-gpu --disable-software-rasterizer --no-sandbox\"",
    "build": "node scripts/generate-icon.js && node scripts/clean-dist.js && tsc -p tsconfig.main.json && vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:debug": "npm run build && electron-builder --win --config.extraMetadata.debugProd=true",
    "release:hashes": "node scripts/release-hashes.js",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "build": {
    "appId": "com.dens.launcher",
    "productName": "DENS Launcher",
    "executableName": "DENSLauncher",
    "copyright": "Copyright © 2026 DENS",
    "directories": {
      "output": "dist-release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/companion-mods",
        "to": "companion-mods"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "DENSLauncher-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "packElevateHelper": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DENS Launcher",
      "include": "build/installer.nsh",
      "artifactName": "DENSLauncher-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "DENSLauncher-Portable-${version}-${arch}.${ext}"
    },
    "asar": true
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
